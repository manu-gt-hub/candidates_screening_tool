"""Shared configuration for CV Ranking and Technical Response Evaluator notebooks.

Usage:
  1. Copy this file as config.py in the same directory as the notebooks
  2. Fill in the values below with your environment-specific settings
  3. config.py is excluded from version control via .gitignore
"""
import os

# ── Resource base path (relative to this config file) ───────────────
_CONFIG_DIR = os.path.dirname(os.path.abspath(__file__))
RESOURCES_BASE = os.path.join(_CONFIG_DIR, "resources")

# ── Input paths ──────────────────────────────────────────────────────
CVS_PATH = os.path.join(RESOURCES_BASE, "cvs_landing")
ROLE_DESCRIPTION_LOCAL_PATH = os.path.join(RESOURCES_BASE, "job_description", "job_description.txt")
TECHNICAL_RESPONSES_PATH = os.path.join(RESOURCES_BASE, "technical_responses", "landing")
LOGO_PATH = os.path.join(RESOURCES_BASE, "images", "logo.png")

# ── Output paths ─────────────────────────────────────────────────────
TECHNICAL_TESTS_OUTPUT_PATH = os.path.join(RESOURCES_BASE, "technical_tests")
EVALUATION_REPORTS_OUTPUT_PATH = os.path.join(RESOURCES_BASE, "report_analysis")
TECHNICAL_ANSWERS_ANALYSIS_PATH = os.path.join(RESOURCES_BASE, "technical_responses", "analysis")

# ── AI model ─────────────────────────────────────────────────────────
AI_MODEL = "databricks-claude-opus-4-6"

# ── Ranking & test generation parameters ─────────────────────────────
# MIN_MATCH_THRESHOLD: minimum match % to generate a technical test.
# Also sets the colour tier boundary in the ranking report (green >= this).
# Ignored when GENERATE_TESTS_FOR_ALL_CANDIDATES is True.
MIN_MATCH_THRESHOLD = 70

# GENERATE_TESTS_FOR_ALL_CANDIDATES: when True, generate technical tests for ALL
# candidates regardless of their match %.
GENERATE_TESTS_FOR_ALL_CANDIDATES = False
